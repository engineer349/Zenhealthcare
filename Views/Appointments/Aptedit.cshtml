@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
    ViewData["Title"] = "EditAppointmentDetails";
    Layout = "_AdminLayout";
}
@model Zencareservice.Models.Appts;

<html>
<head>

</head>
<body> 
    <section class="content-header">
        <div class="container-fluid">
            <div class="row mb-2">
                <div class="col-sm-6">
                    <h1>Appointment</h1>
                </div>
            </div>
            <div class="row mb-2">
                <div class="col-sm-6">
                    <ol class="breadcrumb float-sm-left">
                        <li class="breadcrumb-item"><a asp-action="PAptlist" asp-controller="Appointments">Appointment List</a></li>
                        <li class="breadcrumb-item active">EditAppointment</li>
                    </ol>
                </div>
            </div>
        </div><!-- /.container-fluid -->
    </section>
    <div class="container-fluid">
        <!-- SELECT2 EXAMPLE -->
        <div class="card card-default">
            <div class="card-header">
                <h3 class="card-title">@ViewData["Title"]</h3>
                <div class="card-tools">
                    <button type="button" class="btn btn-tool" data-card-widget="collapse">
                        <i class="fas fa-minus"></i>
                    </button>
                    <button type="button" class="btn btn-tool" data-card-widget="remove">
                        <i class="fas fa-times"></i>
                    </button>
                </div>
            </div>
            <!-- /.card-header -->

           <div class="card-body">

                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="form-row">
                    <div class="form-group col-md-3">
                        <label asp-for="DoctorFirstName">DoctorFirstName</label>
                        <input asp-for="DoctorFirstName" type="text" class="form-control" placeholder="DoctorName">
                        <span asp-validation-for="DoctorFirstName" class="text-danger"></span>
                    </div>
                    <div class="form-group col-md-3">
                        <label asp-for="DoctorLastName">DoctorLastName</label>
                        <input asp-for="DoctorLastName" type="text" class="form-control" placeholder="DoctorName">
                        <span asp-validation-for="DoctorLastName" class="text-danger"></span>
                    </div>
                    <div class="form-group col-md-3">
                        <label asp-for="PatientFirstName">PatientName</label>
                        <input asp-for="PatientFirstName" type="text" class="form-control" id="patientname" placeholder="PatientName">
                        <span asp-validation-for="PatientFirstName" class="text-danger"></span>
                    </div>
                    <div class="form-group col-md-3">
                        <label asp-for="PatientLastName">Patient LastName</label>
                        <input asp-for="PatientLastName" type="text" class="form-control" id="patientname" placeholder="PatientName">
                        <span asp-validation-for="PatientLastName" class="text-danger"></span>
                    </div>
                </div>
    
                <div class="form-row">
                    <div class="form-group col-md-6">
                        <label asp-for="ReasonType">ReasonType</label>
                        <input asp-for="ReasonType" type="text" class="form-control" id="reasontype">
                        <span asp-validation-for="ReasonType" class="text-danger"></span>
                    </div>
                    <div class="form-group col-md-3">
                        <label asp-for="AptBookingDate">AppointmentDate</label>
                        <input asp-for="AptBookingDate" type="date" class="form-control" id="appointmentdate">
                        <span asp-validation-for="AptBookingDate" class="text-danger"></span>
                    </div>
                    <div class="form-group col-md-3">
                        <label asp-for="AptBookingTime">AppointmentTime</label>
                        <input asp-for="AptBookingTime" type="time" class="form-control" id="appointmenttime">
                        <span asp-validation-for="AptBookingTime" class="text-danger"></span>
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group col-md-3">
                        <label for="Reschedule">Reschedule</label>
                        <input for="Reschedule" type="checkbox" id="showInputs" class="form-control">
                    </div>             
                    <div class="form-group col-md-3">
                        <label asp-for="RescheduleAppointmentDate">Reschedule AppointmentDate:</label>
                        <input asp-for="RescheduleAppointmentDate" type="date" id="dateInput" class="form-control">
                    </div>
                    <div class="form-group col-md-3">
                        <label asp-for="RescheduleAppointmentTime">Reschedule AppointmentTime:</label>
                        <input asp-for="RescheduleAppointmentTime" type="time" id="timeInput" class="form-control">
                    </div>
                </div>
            </div>

        </div>
  
        <button type="submit" class="form-submit btn btn-primary" onclick="validateForm()" name="Register">Appointment</button>

    </div>
    </body>

</html>

