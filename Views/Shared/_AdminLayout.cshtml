                                    <p>AdminDashboard</p>
                                </a>
                            </li>

                        </ul>
                    </li>
                    <li class="nav-item">
                        <a asp-action="Calendar" asp-controller="Calendarscheduler" class="nav-link">
                            <i class="nav-icon far fa-calendar-alt"></i>
                            <p>
                                Calendar
                            </p>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="#" class="nav-link">
                            <i class="nav-icon fas fa-edit"></i>
                            <p>
                                Edit
                                <i class="fas fa-angle-left right"></i>
                            </p>
                        </a>
                        <ul class="nav nav-treeview">
                            <li class="nav-item">
                                <a asp-action="Prescedit" asp-controller="Prescriptions" class="nav-link">
                                    <i class='fas fa-prescription' style='font-size:24px'></i>
                                    <p>PrescriptionDetails</p>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a asp-action="Aptedit" asp-controller="Appointments" class="nav-link">
                                    <i class="fa fa-book" style="font-size:24px"></i>
                                    <p>AppointmentDetails</p>
                                </a>
                            </li>
                           @*  <li class="nav-item">
                                <a asp-action="Bedregedit" asp-controller="BedRegistrations" class="nav-link">
                                    <i class='fas fa-procedures' style='font-size:24px'></i>
                                    <p>BedRegistrationDetails</p>
                                </a>
                            </li> *@

                        </ul>
                    </li>
                    <li class="nav-item">
                        <a href="#" class="nav-link">
                            <i class="nav-icon far fa-plus-square"></i>
                            <p>
                                Add
                                <i class="fas fa-angle-left right"></i>
                            </p>
                        </a>
                        <ul class="nav nav-treeview">
                            <li class="nav-item">
                                <a asp-action="Prescrt" asp-controller="Prescriptions" class="nav-link">
                                    <i class='fas fa-prescription' style='font-size:24px'></i>
                                    <p>
                                        PrescriptionDetails
                                    </p>
                                </a>
                            </li>
                        </ul>
                       @*  <ul class="nav nav-treeview">
                            <li class="nav-item">
                                <a asp-action="Bedregcrt" asp-controller="BedRegistrations" class="nav-link">
                                    <i class='fas fa-procedures' style='font-size:24px'></i>
                                    <p>BedRegistrationDetails</p>
                                </a>
                            </li>

                        </ul> *@

                        <ul class="nav nav-treeview">
                            <li class="nav-item">
                                <a asp-action="Aptcrt" asp-controller="Appointments" class="nav-link">
                                        <i class="fa fa-book" style="font-size:24px"></i>
                                    <p> AppointmentDetails</p>
                                </a>
                            </li>
                        </ul>
                    </li>
                    <li class="nav-item">
                    <a href="#" class="nav-link active">

                            <i class="nav-icon fas fa-table"></i>
                            <p>
                                Details
                                <i class="fas fa-angle-left right"></i>
                            </p>
                    </a>
                    <ul class="nav nav-treeview">
                            <li class="nav-item">
                                <a asp-action="Aptlist" asp-controller="Appointments" class="nav-link">
                                    <i class="fa fa-book" style="font-size:24px"></i>
                                    <p>Appointments</p>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a asp-action="Presclist" asp-controller="Prescriptions" class="nav-link active">
                                    <i class='fas fa-prescription' style='font-size:24px'></i>
                                    <p>Prescriptions</p>
                                </a>
                            </li>
                           @*  <li class="nav-item">
                                <a asp-action="Bedreglist" asp-controller="BedRegistrations" class="nav-link">
                                    <i class='fas fa-procedures' style='font-size:24px'></i>
                                    <p>BedRegistrations</p>
                                </a>
                            </li> *@
                        </ul>
                    <li class="nav-item">
                        <a class="nav-link text-dark" id="register" asp-action="AdminRegister" asp-controller="Account"><i class="fas fa-user-plus"></i> Register</a>
                    </li>
                </ul>
            </nav>
            
          </div>
        </aside>


        <div class="content-wrapper">
            <!-- Content Header (Page header) -->
            <section class="content-header">
                <div class="container-fluid">
                    <div class="row mb-2">
                        <div class="col-sm-6">
                        </div>
                        <div class="col-sm-6">
                            <!-- <ol class="breadcrumb float-sm-right"> -->
                            <!-- <li class="breadcrumb-item"><a href="#">Home</a></li> -->
                            <!-- <li class="breadcrumb-item active">Blank Page</li> -->
                            <!-- </ol> -->
                        </div>
                    </div>
                </div><!-- /.container-fluid -->
            </section>

            <section class="content">
                <div class="card-body">
                    @RenderBody()
                </div>

             

            </section>

        </div>

        <div>

            <aside class="control-sidebar control-sidebar-dark">

            </aside>
        </div>
    </div>

    <!-- jQuery -->
    <script src="~/plugins/jquery/jquery.min.js"></script>
    <!-- Bootstrap 4 -->
    <script src="~/plugins/bootstrap/js/bootstrap.bundle.min.js"></script>
    <!-- Zencare App -->
    <script src="~/dist/js/adminlte.min.js"></script>
    <!-- Zencare for demo purposes -->
    <script src="~/dist/js/demo.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        scheduler.init('scheduler_here', new Date(2023, 11, 13), "week");
    </script>
    <script src="https://cdn.dhtmlx.com/scheduler/edge/dhtmlxscheduler.js"></script>
    <link href="https://cdn.dhtmlx.com/scheduler/edge/dhtmlxscheduler_material.css"
