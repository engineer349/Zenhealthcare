@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "USERS";
}
@model Zencareservice.Models.Signup

<section class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1>@ViewBag.Title</h1>
            </div>
        </div>
        <div class="row mb-2">
            <div class="col-sm-6">
                <ol class="breadcrumb float-sm">
                    <li class="breadcrumb-item"><a asp-action="URegister" asp-controller="Account">Create New User</a></li>
                    <li class="breadcrumb-item active">User List</li>
                </ol>
            </div>
        </div>
    </div><!-- /.container-fluid -->
</section>

<div class="card">
    <div class="card-header">
        <h3 class="card-title">User List</h3>
    </div>
    <!-- /.card-header -->
    <div class="card-body">
    
     <table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Employee Code/UserName</th>
            <th>FirstName</th>
            <th>LastName</th>
          
        </tr>
    </thead>
    <tbody>


        @if (Model != null)
        {
            @foreach (var userdetail in Model.showlist)
            {
                <tr>
                    <td>@userdetail.Rcode</td>
                    <td>@userdetail.Firstname</td>
                    <td>@userdetail.Lastname</td>
                     <td> 
                       @Html.ActionLink("Edit","Profile",new{Id =userdetail.Rcode})

                    </td>

                </tr>
            }
        }
        else
        {

        }

    </tbody>
</table>

   </div>
</div>

@section scripts{
    <script>
        $(function () {
            $("#example1").DataTable({
                "responsive": true, "lengthChange": false, "autoWidth": false,
                "buttons": ["copy", "csv", "excel", "pdf", "print", "colvis"]
            }).buttons().container().appendTo('#example1_wrapper .col-md-6:eq(0)');
            $('#example2').DataTable({
                "paging": true,
                "lengthChange": false,
                "searching": false,
                "ordering": true,
                "info": true,
                "autoWidth": false,
                "responsive": true,
            });
        });
    </script>
}